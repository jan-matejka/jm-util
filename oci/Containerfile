ARG registry=localhost
ARG tag=latest
#FROM docker.io/library/debian:trixie-slim
FROM docker.io/library/rust:trixie
# Rust in debian stable is too old to build gitoxide/git-lint

RUN printf "APT::Install-Recommends \"0\";" \
  >/etc/apt/apt.conf.d/no-install-recommends
RUN apt-get update

RUN apt-get install -y \
  make zsh cargo python3-docutils curl gpg ca-certificates git g++ libfmt-dev \
  strace gdb devscripts debhelper-compat build-essential gnupg

RUN apt-get install -y git-buildpackage

COPY wip/oci/jma-ppa.sh /root/
RUN sh /root/jma-ppa.sh

RUN apt-get install -y dram xdgenv libargparse-dev

RUN rustup component add rustfmt

RUN chsh -s /bin/zsh
RUN useradd -m -s /bin/zsh user

RUN <<EOF
set -e
install -d /home/user/git/
git clone https://github.com/jan-matejka/dotfiles-zsh.git /home/user/git/zsh
make -C /home/user/git/zsh install
su -l user -c 'make -C /home/user/git/zsh install'
EOF

USER user
RUN touch /home/user/.zshrc

RUN mkdir /home/user/.gnupg && chmod 700 /home/user/.gnupg

COPY --chown=user:user wip/ /home/user/src
COPY --chown=user:user master/ /home/user/master

WORKDIR /home/user/src
RUN make

COPY --chown=user:user --chmod=0755 wip/oci/entrypoint.sh /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
